# Google Gemini API Key (Required for script and image generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Local ComfyUI API URL for "Enhance Character" features
# Default is http://localhost:8189 if not specified in code
# COMFY_URL=http://localhost:8189

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=henry_db
DB_USER=henry
DB_PASSWORD=example123

# SeaweedFS / S3 Configuration
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=any
S3_SECRET_KEY=any
S3_BUCKET_NAME=movie-script
